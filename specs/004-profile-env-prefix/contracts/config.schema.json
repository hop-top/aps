{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "APS Configuration",
  "type": "object",
  "properties": {
    "prefix": {
      "type": "string",
      "description": "Prefix for injected profile environment variables",
      "default": "APS",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
    }
  },
  "additionalProperties": false
}
